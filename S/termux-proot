#!/data/data/com.termux/files/usr/bin/bash -eu

. "$(dirname "$0")/COMMON"

StartProot() ## ( root ... ) ( preset )
{
	local root="$1" id="0:0" home="/" wd="/" lang="C" \
		path=/usr/sbin:/usr/bin:/sbin:/bin termux android homebind
	shift
	case "$preset" in
	default)
		home="/root" wd="/root" lang="zh_CN.UTF8" termux=1 android=1
		path="/usr/local/sbin:/usr/local/bin:$path"
;;	*)	true
	esac
	[ ! "$termux" ] || path="$path:/data/data/com.termux/files/usr/bin"
	[ ! "$android" ] || path"$path:/system/bin:/vendor/bin:/product/bin"
	unset LD_PRELOAD
	proot -l -r "$root" -i "$id" -w "$wd" -b /dev -b /proc -b /sys \
		-b /apex -b /system -b /linkerconfig/ld.config.txt -b /vendor -b /product \
		-b /data -b /sdcard -b "$HOME":"$home" \
		/usr/bin/env -i HOME="$home" TERM="$TERM" LANG="$lang" \
		PATH="$path" "$@"
}

preset=default StartProot "$@"
