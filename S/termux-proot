import sys
import os
from pathlib import Path
from typing import List

debug_env = 'DEBUGGING'

def print_help() -> None:
    prog = sys.argv[0]
    print(
        prog
        + ": Termux Proot Helper\n      usage: "
        + prog
        + """ ROOT CMDLINE
"""
    )


def main(argv: List[str]) -> int:
    if len(argv) < 2:
        print_help()
        exit(1)

    ## defaults
    root = Path("/")
    id = "0:0"
    wd = Path("/")
    hard_to_sym = True
    binds = ["/dev", "/proc", "/sys"]
    cmdline = ["/bin/sh"]
    # ---
    PATH = "/usr/sbin:/usr/bin:/sbin:/bin"
    HOME = Path("/")
    LANG = "C"
    TERM = os.environ["TERM"]

    ## conf
    root = argv[1]
    cmdline = argv[2:]

    ## process & execute
    opts = ["-r", root, "-i", id, "-w", wd]
    if hard_to_sym:
        opts += ["-l"]
    opts += [item for path in binds for item in ["-b", path]]
    env = {"PATH": PATH, "HOME": HOME, "LANG": LANG, "TERM": TERM}

    if debug_env in os.environ and os.environ[debug_env] == '1':
        print("execvpe(", "proot", ["proot"] + opts + cmdline, env, ")")
    os.execvpe("proot", ["proot"] + opts + cmdline, env)


if __name__ == "__main__":
    exit(main(sys.argv))

