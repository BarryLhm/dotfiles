#!/bin/bash
## not executable, just for syntax highlighting

[ "${_initialized-}" = 1 ] && error "S already initialized" || :
## start of main

[ "${NO_SETEU-}" = 1 ] || set -eu

s_lib=$(realpath "${BASH_SOURCE[0]}")
s_dir=${s_lib%/*}
script=$(realpath "$0")
prog=${0##*/}
errormsg=
errormsg2=

libfunc_register()
{
	local lib=$1 i; shift
	lib=$(printf %q "$lib")
	for i
	do	i=$(printf %q "$i")
		eval "$i(){ unset -f $i; include $lib; $i \"\$@\"; }"
	done
}

## dynloaded functions

libfunc_register misc debugsh justdo countdown head_except
libfunc_register greet banner todo greet
libfunc_register pkg apksize apk_world_dedup pacman_minimize_explicit apt_parse_rdepends apt_minimize_manual
libfunc_register net hitokoto dynv6_update

## Public Functions
call(){ "$@"; }
error(){ echo "$prog: ${errormsg}$1${errormsg2}" >&2; return "${2-1}"; }
is_empty(){ awk 'NF {exit 1}' "$1"; }
include(){ local i; for i; do . "$s_dir/LIB/$i"; done; }
getshpid(){ require linux; grep PPid: "/proc/$$/status" | awk '{print $2}'; }
repeat(){ awk -v n="$1" -v s="$2" 'BEGIN{++n;while(--n)printf "%s",s}'; }
quietly(){ "$@" 2>/dev/null; }

require()
{(
	local quiet=0 i
	local errormsg="error: need "
	local errormsg2=", please check system environment"
	notfound(){ [ "$quiet" != 0 ] || error "${1-"$i"}"; return 1; }
	for i
	do	case "$i" in
		-q) quiet=1;;
		root) [ "$(id -u)" = 0 ] || errormsg2=" privilege" notfound;;
		android|termux) [ "$in_termux" = 1 ] || notfound "android(termux) environment";;
		non_android|non_termux) [ "$in_termux" = 0 ] || notfound "non-android(linux distro) environment";;
		linux) [ "$on_linux" = 1 ] || notfound "system running on linux kernel";;
		python-*) local modname=${i#python-}; python -c "import $modname" || notfound "python module $modname";;
		dir:*) [ -d "${i#dir:}" ] || notfound;;
		file:*) [ -f "${i#file:}" ] || notfound;;
		fsentry:*) [ -e "${i#fsentry:}" ] || notfound "file $i";;
		cmd:*) quietly type "${i#cmd:}" >/dev/null || notfound;;
		*) errormsg="unknown requirement: " errormsg2= notfound;;
		esac
	done
)}

calculate_sum() ### ( column: 1, [file], ... )
{
	local col=${1-}; [ "$col" ] || col=1; [ "$#" = 0 ] || shift
	awk '{gsub(/,/, "", $'"$col"'); sum += $'"$col"'} END {print sum}' "$@"
}

distinfo()
{
	[ "$in_termux" = 0 ] || { echo termux; return; }
require file:/etc/os-release || { echo "unknown"; return; }
	awk -F= -v key="$1" '$1 == key {gsub(/^"|"$/, "", $2); print $2; exit}' /etc/os-release
}

elevate()
{
	[ "$in_termux" = 0 ] || { "$@"; return; }
	for i in sudo doas
	do	quietly require cmd:"$i" && "$i" -- "$@"
		return
	done
	error "no elevator available"
}

[ "${TERMUX_VERSION+x}" ] && in_termux=1 || in_termux=0
case "$(uname -s)" in
Linux|MSYS*) on_linux=1;;
*) on_linux=0;;
esac
[ "$TERM" = "linux" ] && in_fbcon=1 || in_fbcon=0
require cmd:tput
[ "${COLUMNS-}" ] || COLUMNS="$(tput cols)"

## end of main
_initialized=1
