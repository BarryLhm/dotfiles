        (proc-arg 9 "GimpParamDrawable" "GimpDrawable" "sample-drawable" "еПѓзїШеМЇйЗЗж†Ј" "еПѓзїШеМЇйЗЗж†ЈпЉИеЇФдЄЇ RGB жИЦ RGBA з±їеЮЛпЉЙ" 3 1)
