        (proc-arg 5 "GParamBoolean" "gboolean" "orig-inten" "еОЯеІЛеЉЇеЇ¶(_N)" "TRUEпЉЪдњЭжМБеОЯеІЛеЉЇеЇ¶зЇІеИЂзЪДдЇЃеЇ¶пЉМFALSEпЉЪдњЭжМБиЊУеЕ•зЇІеИЂзЪДеЉЇеЇ¶" 3 1)
        (proc-arg 5 "GParamBoolean" "gboolean" "rnd-subcolors" "дљњзФ®е≠РйҐЬиЙ≤(_E)" "TRUEпЉЪдљњзФ®зЫЄеРМеЉЇеЇ¶зЪДеЕ®йГ®е≠РйҐЬиЙ≤пЉМFALSEпЉЪжѓПдЄ™еЉЇеЇ¶дїЕдљњзФ®дЄАзІНйҐЬиЙ≤" 3 0)
