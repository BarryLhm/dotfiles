        (proc-arg 1 "GParamInt" "gint" "in-low" "дљО(_L)" "жЬАдљОиЊУеЕ•зЪДеЉЇеЇ¶" 3 0 254 0)
        (proc-arg 1 "GParamInt" "gint" "in-high" "йЂШ(_H)" "жЬАйЂШиЊУеЕ•зЪДеЉЇеЇ¶" 3 1 255 255)
        (proc-arg 6 "GParamDouble" "gdouble" "gamma" "дЉљй©ђ(_M)" "дЉљй©ђи∞ГжХіз≥їжХ∞пЉМ1.0 дЄЇзЇњжАІ" 3 0.10000000000000001 10 1)
